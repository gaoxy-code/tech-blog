{
	"name": "tech-blog",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
	"scripts": {
		"dev": "vite dev",
		"build": "wrangler types && node --env-file-if-exists=.env scripts/fetch-views.mjs && vite build && pagefind --site .svelte-kit/cloudflare",
		"preview": "wrangler pages dev .svelte-kit/cloudflare --port 4173",
		"prepare": "(svelte-kit sync || true) && (lefthook install || true) && (node --env-file-if-exists=.env scripts/fetch-views.mjs || true) && (wrangler types || true)",
		"check": "wrangler types && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"test:coverage": "vitest --run --coverage",
		"gen": "wrangler types"
	},
	"devDependencies": {
		"@eslint/compat": "latest",
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/geist": "^5.2.8",
		"@internationalized/date": "^3.12.1",
		"@lucide/svelte": "^1.8.0",
		"@resvg/resvg-js": "^2.6.2",
		"@sveltejs/adapter-cloudflare": "latest",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^24",
		"@vitest/browser-playwright": "^4.1.5",
		"@vitest/coverage-v8": "^4.1.5",
		"bits-ui": "^2.17.3",
		"clsx": "^2.1.1",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"gray-matter": "^4.0.3",
		"lefthook": "^2.1.6",
		"marked": "^18.0.2",
		"mdsvex": "^0.12.7",
		"pagefind": "^1.5.2",
		"playwright": "^1.59.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.2",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"rehype-slug": "^6.0.0",
		"satori": "^0.26.0",
		"shadcn-svelte": "^1.2.7",
		"shiki": "^4.0.2",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7",
		"vitest": "^4.1.5",
		"vitest-browser-svelte": "^2.1.0",
		"wrangler": "^4.81.0"
	}
}
